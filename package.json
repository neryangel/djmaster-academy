{
  "name": "djmaster-academy",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "DJMaster Academy — Professional DJ Learning Platform",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "lint": "prettier --check . && markdownlint-cli2 '**/*.md' '#node_modules'",
    "lint:fix": "prettier --write . && markdownlint-cli2-fix '**/*.md' '#node_modules'",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "prepare": "husky",
    "validate": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.7",
    "@astrojs/mdx": "^4.0.8",
    "@astrojs/react": "^4.4.0",
    "@astrojs/starlight": "^0.31.1",
    "@astrojs/starlight-tailwind": "^2.0.3",
    "@astrojs/tailwind": "^5.1.5",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^5.18.0",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.577.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitest/coverage-v8": "^2.1.0",
    "happy-dom": "^15.11.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.5.0",
    "markdownlint-cli2": "^0.14.0",
    "prettier": "^3.8.0",
    "prettier-plugin-astro": "^0.14.0",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "vitest": "^2.1.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,astro}": [
      "prettier --write"
    ],
    "*.md": [
      "markdownlint-cli2-fix",
      "prettier --write"
    ],
    "*.{json,yaml,yml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
