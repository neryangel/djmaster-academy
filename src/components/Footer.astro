---
interface Props {
  variant?: 'full' | 'simple';
}

const { variant = 'simple' } = Astro.props;
---

{variant === 'full' ? (
  <footer class="border-t border-white/10 pt-12 pb-6 px-6">
    <div class="max-w-[1200px] mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-10">
        <!-- Brand -->
        <div class="md:col-span-2">
          <div class="text-xl font-[800] text-gradient mb-3">DJMaster Academy</div>
          <p class="text-white/60 text-sm leading-relaxed max-w-md">
            הפלטפורמה המובילה ללימוד DJ בעברית. קורסים מקצועיים, כלים אינטראקטיביים, ותמיכה של מנטורים אמיתיים — מתחיל מאפס ועד לבמה.
          </p>
        </div>
        <!-- Quick Links -->
        <div>
          <h4 class="font-bold text-sm mb-4 text-white/70">ניווט מהיר</h4>
          <div class="flex flex-col gap-2">
            <a href="/courses" class="footer-link">📚 קורסים</a>
            <a href="/tools" class="footer-link">🎛️ כלים</a>
            <a href="/courses/world-of-dj" class="footer-link">🌍 עולם הדי-ג'יי</a>
            <a href="/courses/rekordbox" class="footer-link">💻 Rekordbox</a>
          </div>
        </div>
        <!-- Tools -->
        <div>
          <h4 class="font-bold text-sm mb-4 text-white/70">כלים מובילים</h4>
          <div class="flex flex-col gap-2">
            <a href="/tools/bpm-calculator" class="footer-link">🥁 מחשבון BPM</a>
            <a href="/tools/harmonic-wheel" class="footer-link">🎡 גלגל הרמוני</a>
            <a href="/tools/beatmatch-trainer" class="footer-link">🎯 אימון Beatmatch</a>
            <a href="/tools/eq-trainer" class="footer-link">🎚️ אימון EQ</a>
          </div>
        </div>
      </div>
      <!-- Bottom bar -->
      <div class="border-t border-white/5 pt-6 flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-white/50 text-sm">© 2026 DJMaster Academy. כל הזכויות שמורות.</p>
        <p class="text-white/50 text-sm">❤️ בעבור כל ה-DJ-ים בעברית</p>
      </div>
    </div>
  </footer>
) : (
  <footer class="border-t border-white/10 py-8 mt-16">
    <div class="max-w-7xl mx-auto px-4 text-center text-white/50 text-sm">
      <p>© 2026 DJMaster Academy. כל הזכויות שמורות.</p>
    </div>
  </footer>
)}
