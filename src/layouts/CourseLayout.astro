---
import BaseLayout from './BaseLayout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';

interface CourseProps {
  title: string;
  description: string;
  level: string;
  duration: number;
  lessonCount: number;
}

const { title, description, level, duration, lessonCount } = Astro.props as unknown as CourseProps;

const levelLabels: Record<string, string> = {
  beginner: 'מתחיל',
  intermediate: 'בינוני',
  advanced: 'מתקדם',
};
const levelColors: Record<string, string> = {
  beginner: 'bg-[#00E5FF]/10 text-[#00E5FF] border border-[#00E5FF]/20',
  intermediate: 'bg-[#7b2fff]/10 text-[#d4b5ff] border border-[#7b2fff]/30',
  advanced: 'bg-[#FF0055]/10 text-[#FF0055] border border-[#FF0055]/30',
};
---

<BaseLayout title={title} description={description}>
  <Navbar activePage="courses" />

  <!-- Course Hero -->
  <section class="py-12 relative overflow-hidden mt-16 bg-[#09090b] border-b border-white/5">
    <div class="absolute inset-0 bg-gradient-to-b from-[#00E5FF]/5 to-transparent pointer-events-none"></div>
    <div class="max-w-[1200px] mx-auto px-6 relative z-10">
      <div class="flex items-center gap-3 mb-6">
        <span class={`px-2.5 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest ${levelColors[level] || ''}`}>
          {levelLabels[level] || level}
        </span>
        <span class="text-white/40 text-xs font-mono tracking-widest">{duration} דקות</span>
        <span class="text-white/20 text-sm">•</span>
        <span class="text-white/40 text-xs font-mono tracking-widest">{lessonCount} MODULES</span>
      </div>
      <h1 class="text-4xl md:text-5xl font-[900] mb-4 tracking-tight shadow-sm text-transparent bg-clip-text bg-gradient-to-l from-white to-white/70">{title}</h1>
      <p class="text-white/70 text-lg max-w-2xl">{description}</p>
    </div>
  </section>

  <!-- Course Content -->
  <main class="max-w-[1200px] mx-auto px-6 py-12">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      <!-- Sidebar -->
      <aside class="lg:col-span-1 order-2 lg:order-1">
        <div class="sticky top-24 bg-[#121217] border border-white/10 rounded-2xl p-6 shadow-xl">
          <h3 class="text-xs font-bold mb-4 text-[#00E5FF] uppercase tracking-[0.2em]">תוכן הקורס</h3>
          <hr class="border-white/5 mb-4" />
          <slot name="sidebar" />
        </div>
      </aside>
      <!-- Main Content -->
      <div class="lg:col-span-3 order-1 lg:order-2">
        <slot />
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
