---
import BaseLayout from './BaseLayout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';

interface Props {
  title: string;
  description: string;
  icon: string;
  maxWidth?: string;
}

const { title, description, icon, maxWidth = 'max-w-4xl' } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <Navbar
    variant="breadcrumb"
    breadcrumbs={[
      { label: 'כלים', href: '/tools' },
      { label: title },
    ]}
  />

  <main class={`${maxWidth} mx-auto px-4 md:px-8 py-12 mt-16 transition-all duration-300`}>
    <div class="mb-8 text-center fade-in-up">
      <span class="text-5xl mb-4 block">{icon}</span>
      <h1 class="text-3xl md:text-4xl font-bold mb-2">{title}</h1>
      <p class="text-white/70">{description}</p>
    </div>
    <div class="glass-card p-6 md:p-8">
      <slot />
    </div>
  </main>

  <Footer />
</BaseLayout>
