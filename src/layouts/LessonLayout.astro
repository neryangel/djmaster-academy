---
import BaseLayout from './BaseLayout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';

interface LessonProps {
  title: string;
  description?: string;
  courseTitle: string;
  courseSlug: string;
  lessonNumber: number;
  totalLessons: number;
  duration?: number;
  difficulty?: string;
  keyTerms?: Array<{ term: string; definition: string }>;
  prevLesson?: { title: string; slug: string } | null;
  nextLesson?: { title: string; slug: string } | null;
}

const {
  title, description, courseTitle, courseSlug,
  lessonNumber, totalLessons, duration, difficulty,
  keyTerms, prevLesson, nextLesson
} = Astro.props as unknown as LessonProps;

const levelLabels: Record<string, string> = {
  beginner: 'מתחיל', intermediate: 'בינוני', advanced: 'מתקדם',
};
const levelColors: Record<string, string> = {
  beginner: 'bg-green-500/20 text-green-400',
  intermediate: 'bg-yellow-500/20 text-yellow-400',
  advanced: 'bg-red-500/20 text-red-400',
};
const progress = Math.round((lessonNumber / totalLessons) * 100);
---

<BaseLayout title={`${title} | ${courseTitle}`} description={description || title}>
  <Navbar
    variant="breadcrumb"
    breadcrumbs={[
      { label: 'קורסים', href: '/courses' },
      { label: courseTitle, href: `/courses/${courseSlug}` },
      { label: `שיעור ${lessonNumber}` },
    ]}
  />

  <!-- Lesson Hero -->
  <section class="pt-24 pb-8 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-[#00d4ff]/5 to-transparent pointer-events-none"></div>
    <div class="max-w-5xl mx-auto px-4 relative z-10">
      <div class="flex items-center gap-3 mb-4 flex-wrap">
        <span class="text-sm font-mono text-[#00d4ff] bg-[#00d4ff]/10 px-3 py-1 rounded-full">
          שיעור {lessonNumber} מתוך {totalLessons}
        </span>
        {difficulty && (
          <span class={`px-3 py-1 rounded-full text-xs font-medium ${levelColors[difficulty] || ''}`}>
            {levelLabels[difficulty] || difficulty}
          </span>
        )}
        {duration && (
          <span class="text-white/60 text-sm">⏱️ {duration} דק'</span>
        )}
      </div>
      <h1 class="text-3xl md:text-4xl font-bold">{title}</h1>
    </div>
  </section>

  <!-- Progress Bar -->
  <div class="max-w-5xl mx-auto px-4 mb-8">
    <div class="h-1.5 bg-white/10 rounded-full overflow-hidden">
      <div class="h-full bg-gradient-to-l from-[#00d4ff] to-[#7b2fff] rounded-full progress-glow transition-all duration-500" style={`width: ${progress}%`}></div>
    </div>
  </div>

  <!-- Content -->
  <main class="max-w-5xl mx-auto px-4 pb-16">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      <!-- Sidebar -->
      <aside class="lg:col-span-1 order-2 lg:order-1">
        <!-- Syllabus Slot -->
        <slot name="sidebar" />

        <!-- Key Terms -->
        {keyTerms && keyTerms.length > 0 && (
          <div class="glass-card p-5 mb-6 sticky top-24">
            <h3 class="text-sm font-bold text-[#00d4ff] mb-3 uppercase tracking-wide">📚 מונחים חשובים</h3>
            <div class="space-y-3">
              {keyTerms.map((term) => (
                <div>
                  <div class="font-semibold text-sm text-white">{term.term}</div>
                  <div class="text-white/70 text-xs leading-relaxed">{term.definition}</div>
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Progress Card -->
        <div class="glass-card p-5">
          <h3 class="text-sm font-bold text-[#00d4ff] mb-3 uppercase tracking-wide">📊 התקדמות</h3>
          <div class="text-3xl font-bold font-mono text-gradient">{progress}%</div>
          <div class="text-white/60 text-xs mt-1">{lessonNumber} מתוך {totalLessons} שיעורים</div>
          <div class="mt-3 h-2 bg-white/10 rounded-full overflow-hidden">
            <div class="h-full bg-gradient-to-l from-[#00d4ff] to-[#7b2fff] rounded-full progress-glow" style={`width: ${progress}%`}></div>
          </div>
        </div>
      </aside>

      <!-- Content -->
      <div class="lg:col-span-3 order-1 lg:order-2">
        <article class="lesson-prose">
          <slot />
        </article>

        <!-- Navigation -->
        <nav class="mt-12 pt-8 border-t border-white/10 grid grid-cols-1 sm:grid-cols-2 gap-4">
          {prevLesson ? (
            <a href={`/courses/${courseSlug}/${prevLesson.slug}`} class="group glass-card p-4 glow-hover hover:border-[#7b2fff]/50 transition-all">
              <div class="text-xs text-white/60 mb-1">← שיעור קודם</div>
              <div class="text-white font-semibold group-hover:text-[#00d4ff] transition">{prevLesson.title}</div>
            </a>
          ) : <div />}
          {nextLesson ? (
            <a href={`/courses/${courseSlug}/${nextLesson.slug}`} class="group glass-card p-4 glow-hover hover:border-[#00d4ff]/50 transition-all text-left">
              <div class="text-xs text-white/60 mb-1">שיעור הבא →</div>
              <div class="text-white font-semibold group-hover:text-[#00d4ff] transition">{nextLesson.title}</div>
            </a>
          ) : (
            <a href={`/courses/${courseSlug}`} class="group glass-card p-4 bg-gradient-to-l from-[#7b2fff]/10 to-[#00d4ff]/10 border-[#00d4ff]/30 hover:border-[#00d4ff]/60 transition-all text-left">
              <div class="text-xs text-white/60 mb-1">🎉 סיימת!</div>
              <div class="text-white font-semibold group-hover:text-[#00d4ff] transition">חזרה לדף הקורס</div>
            </a>
          )}
        </nav>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
