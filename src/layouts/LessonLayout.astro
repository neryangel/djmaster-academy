---
import '../styles/global.css';
import '../styles/custom.css';

interface LessonProps {
  title: string;
  description?: string;
  courseTitle: string;
  courseSlug: string;
  lessonNumber: number;
  totalLessons: number;
  duration?: number;
  difficulty?: string;
  keyTerms?: Array<{ term: string; definition: string }>;
  prevLesson?: { title: string; slug: string } | null;
  nextLesson?: { title: string; slug: string } | null;
}

const {
  title, description, courseTitle, courseSlug,
  lessonNumber, totalLessons, duration, difficulty,
  keyTerms, prevLesson, nextLesson
} = Astro.props as unknown as LessonProps;

const levelLabels: Record<string, string> = {
  beginner: 'מתחיל', intermediate: 'בינוני', advanced: 'מתקדם',
};
const levelColors: Record<string, string> = {
  beginner: 'bg-green-500/20 text-green-400',
  intermediate: 'bg-yellow-500/20 text-yellow-400',
  advanced: 'bg-red-500/20 text-red-400',
};
const progress = Math.round((lessonNumber / totalLessons) * 100);
---

<html lang="he" dir="rtl" class="scroll-smooth">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} | {courseTitle} | DJMaster Academy</title>
  <meta name="description" content={description || title} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
</head>
<body class="bg-[#0A0A0F] text-white font-hebrew min-h-screen">
  <!-- Header -->
  <header class="border-b border-white/10 bg-[#0A0A0F]/95 backdrop-blur-xl sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 py-4">
      <nav class="flex items-center justify-between">
        <a href="/" class="text-xl font-bold bg-gradient-to-l from-[#00d4ff] to-[#7b2fff] bg-clip-text text-transparent">
          DJMaster Academy
        </a>
        <div class="flex items-center gap-4 text-sm">
          <a href="/courses" class="text-white/60 hover:text-white transition">קורסים</a>
          <span class="text-white/30">›</span>
          <a href={`/courses/${courseSlug}`} class="text-white/60 hover:text-white transition">{courseTitle}</a>
          <span class="text-white/30">›</span>
          <span class="text-white/90">שיעור {lessonNumber}</span>
        </div>
      </nav>
    </div>
    <!-- Progress bar -->
    <div class="h-1 bg-white/5">
      <div class="h-full bg-gradient-to-l from-[#00d4ff] to-[#7b2fff] transition-all duration-500" style={`width: ${progress}%`}></div>
    </div>
  </header>

  <!-- Lesson Hero -->
  <section class="py-8 bg-gradient-to-b from-[#7b2fff]/10 to-transparent border-b border-white/5">
    <div class="max-w-4xl mx-auto px-4">
      <div class="flex items-center gap-3 mb-3 flex-wrap">
        <span class="text-sm font-mono text-[#00d4ff] bg-[#00d4ff]/10 px-3 py-1 rounded-lg">
          שיעור {lessonNumber} מתוך {totalLessons}
        </span>
        {difficulty && (
          <span class={`px-3 py-1 rounded-full text-xs font-medium ${levelColors[difficulty] || ''}`}>
            {levelLabels[difficulty] || difficulty}
          </span>
        )}
        {duration && (
          <span class="text-white/40 text-sm">⏱️ {duration} דק'</span>
        )}
      </div>
      <h1 class="text-3xl md:text-4xl font-bold">{title}</h1>
      {description && <p class="text-white/60 mt-2 text-lg">{description}</p>}
    </div>
  </section>

  <!-- Main Content -->
  <main class="max-w-7xl mx-auto px-4 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
      <!-- Sidebar -->
      <aside class="lg:col-span-1 order-2 lg:order-1">
        <div class="sticky top-24 space-y-6">
          {/* Key Terms */}
          {keyTerms && keyTerms.length > 0 && (
            <div class="bg-white/5 rounded-2xl p-5 border border-white/10">
              <h3 class="text-sm font-bold text-[#7b2fff] mb-3 uppercase tracking-wide">📚 מונחים חשובים</h3>
              <div class="space-y-3">
                {keyTerms.map((term) => (
                  <div class="text-sm">
                    <span class="text-white font-semibold">{term.term}</span>
                    <p class="text-white/50 text-xs mt-0.5 leading-relaxed">{term.definition}</p>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Progress */}
          <div class="bg-white/5 rounded-2xl p-5 border border-white/10">
            <h3 class="text-sm font-bold text-[#00d4ff] mb-3 uppercase tracking-wide">📊 התקדמות</h3>
            <div class="text-3xl font-bold font-mono text-[#00d4ff]">{progress}%</div>
            <div class="text-white/40 text-xs mt-1">{lessonNumber} מתוך {totalLessons} שיעורים</div>
            <div class="mt-3 h-2 bg-white/10 rounded-full overflow-hidden">
              <div class="h-full bg-gradient-to-l from-[#00d4ff] to-[#7b2fff] rounded-full" style={`width: ${progress}%`}></div>
            </div>
          </div>
        </div>
      </aside>

      <!-- Content -->
      <div class="lg:col-span-3 order-1 lg:order-2">
        <article class="lesson-prose">
          <slot />
        </article>

        <!-- Navigation -->
        <nav class="mt-12 pt-8 border-t border-white/10 grid grid-cols-1 sm:grid-cols-2 gap-4">
          {prevLesson ? (
            <a href={`/courses/${courseSlug}/${prevLesson.slug}`} class="group bg-white/5 border border-white/10 rounded-xl p-4 hover:border-[#7b2fff]/50 transition-all">
              <div class="text-xs text-white/40 mb-1">← שיעור קודם</div>
              <div class="text-white font-semibold group-hover:text-[#00d4ff] transition">{prevLesson.title}</div>
            </a>
          ) : <div />}
          {nextLesson ? (
            <a href={`/courses/${courseSlug}/${nextLesson.slug}`} class="group bg-white/5 border border-white/10 rounded-xl p-4 hover:border-[#00d4ff]/50 transition-all text-left">
              <div class="text-xs text-white/40 mb-1">שיעור הבא →</div>
              <div class="text-white font-semibold group-hover:text-[#00d4ff] transition">{nextLesson.title}</div>
            </a>
          ) : (
            <a href={`/courses/${courseSlug}`} class="group bg-gradient-to-l from-[#7b2fff]/20 to-[#00d4ff]/20 border border-[#00d4ff]/30 rounded-xl p-4 hover:border-[#00d4ff]/60 transition-all text-left">
              <div class="text-xs text-white/40 mb-1">🎉 סיימת!</div>
              <div class="text-white font-semibold group-hover:text-[#00d4ff] transition">חזרה לדף הקורס</div>
            </a>
          )}
        </nav>
      </div>
    </div>
  </main>

  <!-- Footer -->
  <footer class="border-t border-white/10 py-8 mt-16">
    <div class="max-w-7xl mx-auto px-4 text-center text-white/40 text-sm">
      <p>© 2026 DJMaster Academy. כל הזכויות שמורות.</p>
    </div>
  </footer>
</body>
</html>
