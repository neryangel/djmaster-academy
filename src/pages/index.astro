---
// DJMaster Academy Landing Page
---

<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>DJMaster Academy — לימוד DJ מקצועי</title>
  <meta name="description" content="הפלטפורמה המובילה ללימוד DJ בעברית. 5 קורסים מקצועיים, כלים אינטראקטיביים, ותמיכה של מנטורים אמיתיים — מתחיל מאפס ועד לבמה." />
  <meta property="og:title" content="DJMaster Academy — לימוד DJ מקצועי" />
  <meta property="og:description" content="הפלטפורמה המובילה ללימוד DJ בעברית. 5 קורסים, כלים אינטראקטיביים, ומנטורים אמיתיים." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://djmaster-academy.vercel.app" />
  <meta property="og:locale" content="he_IL" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700;800;900&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Heebo', sans-serif; background: #0A0A0F; color: #fff; }
    .gradient-text { background: linear-gradient(135deg, #00d4ff, #7b2fff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .hero-glow { position: absolute; width: 600px; height: 600px; border-radius: 50%; filter: blur(120px); opacity: 0.15; pointer-events: none; }
    .card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 16px; padding: 2rem; transition: all 0.3s; }
    .card:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.2); transform: translateY(-4px); }
    .btn-primary { background: linear-gradient(135deg, #7b2fff, #00d4ff); padding: 14px 32px; border-radius: 12px; font-weight: 700; font-size: 1.1rem; border: none; color: white; cursor: pointer; transition: all 0.3s; display: inline-block; text-decoration: none; }
    .btn-primary:hover { transform: scale(1.05); box-shadow: 0 0 30px rgba(123,47,255,0.4); }
    .btn-secondary { background: rgba(255,255,255,0.1); padding: 14px 32px; border-radius: 12px; font-weight: 600; border: 1px solid rgba(255,255,255,0.2); color: white; cursor: pointer; transition: all 0.3s; display: inline-block; text-decoration: none; }
    .btn-secondary:hover { background: rgba(255,255,255,0.15); }
    .tool-icon { font-size: 2.5rem; margin-bottom: 1rem; display: block; }
    .stat-number { font-family: 'Space Mono', monospace; font-size: 2.5rem; font-weight: 700; }
    @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
    .float { animation: float 3s ease-in-out infinite; }
  </style>
</head>
<body>
  <!-- Navigation -->
  <nav style="position: fixed; top: 0; width: 100%; z-index: 100; background: rgba(10,10,15,0.9); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255,255,255,0.1);">
    <div style="max-width: 1200px; margin: 0 auto; padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between;">
      <span style="font-size: 1.5rem; font-weight: 800;" class="gradient-text">DJMaster Academy</span>
      <div style="display: flex; gap: 2rem; align-items: center;">
        <a href="/courses" style="color: rgba(255,255,255,0.7); text-decoration: none;">קורסים</a>
        <a href="/tools" style="color: rgba(255,255,255,0.7); text-decoration: none;">כלים</a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section style="min-height: 100vh; display: flex; align-items: center; position: relative; overflow: hidden; padding-top: 80px;">
    <div class="hero-glow" style="background: #7b2fff; top: -200px; right: -200px;"></div>
    <div class="hero-glow" style="background: #00d4ff; bottom: -200px; left: -200px;"></div>
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 2rem; position: relative; z-index: 1; text-align: center;">
      <div style="margin-bottom: 1.5rem;">
        <span style="background: rgba(123,47,255,0.2); color: #b794ff; padding: 6px 16px; border-radius: 20px; font-size: 0.9rem;">🎧 הפלטפורמה המובילה ללימוד DJ בעברית</span>
      </div>
      <h1 style="font-size: clamp(2.5rem, 6vw, 4.5rem); font-weight: 900; line-height: 1.2; margin-bottom: 1.5rem;">
        תהפוך ל<span class="gradient-text">DJ מקצועי</span><br/>עם הקורס הכי מקיף בישראל
      </h1>
      <p style="font-size: 1.25rem; color: rgba(255,255,255,0.6); max-width: 600px; margin: 0 auto 2.5rem; line-height: 1.8;">
        מתחיל מאפס ועד לבמה. 5 קורסים מקצועיים, כלים אינטראקטיביים, ותמיכה של מנטורים אמיתיים.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/courses" class="btn-primary">🚀 התחל ללמוד בחינם</a>
        <a href="/tools" class="btn-secondary">🎛️ נסה את הכלים</a>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section style="padding: 4rem 2rem; border-top: 1px solid rgba(255,255,255,0.05);">
    <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; text-align: center;">
      <div><div class="stat-number gradient-text">5</div><div style="color: rgba(255,255,255,0.5); margin-top: 0.5rem;">קורסים מקצועיים</div></div>
      <div><div class="stat-number gradient-text">24</div><div style="color: rgba(255,255,255,0.5); margin-top: 0.5rem;">שיעורים אינטראקטיביים</div></div>
      <div><div class="stat-number gradient-text">5</div><div style="color: rgba(255,255,255,0.5); margin-top: 0.5rem;">כלי DJ מתקדמים</div></div>
      <div><div class="stat-number gradient-text">100%</div><div style="color: rgba(255,255,255,0.5); margin-top: 0.5rem;">בעברית</div></div>
    </div>
  </section>

  <!-- Courses Preview -->
  <section style="padding: 5rem 2rem;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-size: 2.5rem; font-weight: 800; text-align: center; margin-bottom: 1rem;">המסלול שלך ל<span class="gradient-text">הצלחה</span></h2>
      <p style="text-align: center; color: rgba(255,255,255,0.5); margin-bottom: 3rem;">5 קורסים שיקחו אותך מאפס לדי-ג'יי מקצועי</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
        <div class="card">
          <span style="font-size: 2rem;">🌍</span>
          <h3 style="font-size: 1.25rem; font-weight: 700; margin: 0.75rem 0 0.5rem;">עולם הדי-ג'יי</h3>
          <p style="color: rgba(255,255,255,0.5); font-size: 0.95rem; line-height: 1.6;">היכרות מקיפה — מה זה DJ, ציוד, קריירה</p>
          <div style="margin-top: 1rem; display: flex; gap: 0.5rem;">
            <span style="background: rgba(34,197,94,0.2); color: #4ade80; padding: 2px 10px; border-radius: 8px; font-size: 0.8rem;">מתחיל</span>
            <span style="color: rgba(255,255,255,0.3); font-size: 0.8rem;">6 שיעורים</span>
          </div>
        </div>
        <div class="card">
          <span style="font-size: 2rem;">🎵</span>
          <h3 style="font-size: 1.25rem; font-weight: 700; margin: 0.75rem 0 0.5rem;">תורת המוזיקה ל-DJ</h3>
          <p style="color: rgba(255,255,255,0.5); font-size: 0.95rem; line-height: 1.6;">BPM, מפתחות, מבנה שירים, ומיקס הרמוני</p>
          <div style="margin-top: 1rem; display: flex; gap: 0.5rem;">
            <span style="background: rgba(34,197,94,0.2); color: #4ade80; padding: 2px 10px; border-radius: 8px; font-size: 0.8rem;">מתחיל</span>
            <span style="color: rgba(255,255,255,0.3); font-size: 0.8rem;">8 שיעורים</span>
          </div>
        </div>
        <div class="card">
          <span style="font-size: 2rem;">🎛️</span>
          <h3 style="font-size: 1.25rem; font-weight: 700; margin: 0.75rem 0 0.5rem;">Rekordbox — מדריך מלא</h3>
          <p style="color: rgba(255,255,255,0.5); font-size: 0.95rem; line-height: 1.6;">ניהול ספרייה, ניתוח, והכנה לביצוע</p>
          <div style="margin-top: 1rem; display: flex; gap: 0.5rem;">
            <span style="background: rgba(234,179,8,0.2); color: #fbbf24; padding: 2px 10px; border-radius: 8px; font-size: 0.8rem;">בינוני</span>
            <span style="color: rgba(255,255,255,0.3); font-size: 0.8rem;">10 שיעורים</span>
          </div>
        </div>
        <div class="card">
          <span style="font-size: 2rem;">🎚️</span>
          <h3 style="font-size: 1.25rem; font-weight: 700; margin: 0.75rem 0 0.5rem;">טכניקות מיקס</h3>
          <p style="color: rgba(255,255,255,0.5); font-size: 0.95rem; line-height: 1.6;">Beatmatch, EQ mixing, transitions, effects</p>
          <div style="margin-top: 1rem; display: flex; gap: 0.5rem;">
            <span style="background: rgba(234,179,8,0.2); color: #fbbf24; padding: 2px 10px; border-radius: 8px; font-size: 0.8rem;">בינוני</span>
            <span style="color: rgba(255,255,255,0.3); font-size: 0.8rem;">12 שיעורים</span>
          </div>
        </div>
        <div class="card">
          <span style="font-size: 2rem;">⭐</span>
          <h3 style="font-size: 1.25rem; font-weight: 700; margin: 0.75rem 0 0.5rem;">בניית סט ובמה</h3>
          <p style="color: rgba(255,255,255,0.5); font-size: 0.95rem; line-height: 1.6;">תכנון סטים, קריאת קהל, ובניית קריירה</p>
          <div style="margin-top: 1rem; display: flex; gap: 0.5rem;">
            <span style="background: rgba(239,68,68,0.2); color: #f87171; padding: 2px 10px; border-radius: 8px; font-size: 0.8rem;">מתקדם</span>
            <span style="color: rgba(255,255,255,0.3); font-size: 0.8rem;">8 שיעורים</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Tools Section -->
  <section style="padding: 5rem 2rem; background: rgba(123,47,255,0.03);">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-size: 2.5rem; font-weight: 800; text-align: center; margin-bottom: 1rem;">כלים <span class="gradient-text">אינטראקטיביים</span></h2>
      <p style="text-align: center; color: rgba(255,255,255,0.5); margin-bottom: 3rem;">תרגול מעשי ישירות בדפדפן</p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem;">
        <a href="/tools/bpm-calculator" class="card" style="text-decoration: none; text-align: center;">
          <span class="tool-icon">🥁</span>
          <h3 style="font-weight: 700;">מחשבון BPM</h3>
          <p style="color: rgba(255,255,255,0.4); font-size: 0.85rem;">זיהוי קצב בטאפ</p>
        </a>
        <a href="/tools/harmonic-wheel" class="card" style="text-decoration: none; text-align: center;">
          <span class="tool-icon">🎡</span>
          <h3 style="font-weight: 700;">גלגל הרמוני</h3>
          <p style="color: rgba(255,255,255,0.4); font-size: 0.85rem;">התאמת מפתחות</p>
        </a>
        <a href="/tools/eq-trainer" class="card" style="text-decoration: none; text-align: center;">
          <span class="tool-icon">🎚️</span>
          <h3 style="font-weight: 700;">אימון EQ</h3>
          <p style="color: rgba(255,255,255,0.4); font-size: 0.85rem;">פיתוח אוזן</p>
        </a>
        <a href="/tools/beatmatch-trainer" class="card" style="text-decoration: none; text-align: center;">
          <span class="tool-icon">🎯</span>
          <h3 style="font-weight: 700;">אימון Beatmatch</h3>
          <p style="color: rgba(255,255,255,0.4); font-size: 0.85rem;">סינכרון ביטים</p>
        </a>
        <a href="/tools/set-planner" class="card" style="text-decoration: none; text-align: center;">
          <span class="tool-icon">📋</span>
          <h3 style="font-weight: 700;">מתכנן סטים</h3>
          <p style="color: rgba(255,255,255,0.4); font-size: 0.85rem;">בניית סט מושלם</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section style="padding: 5rem 2rem; text-align: center;">
    <h2 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 1rem;">מוכן להתחיל?</h2>
    <p style="color: rgba(255,255,255,0.5); margin-bottom: 2rem;">הקורס הראשון בחינם. בלי התחייבות.</p>
    <a href="/courses/world-of-dj" class="btn-primary" style="font-size: 1.2rem; padding: 16px 40px;">🎧 התחל עכשיו — בחינם</a>
  </section>

  <footer style="border-top: 1px solid rgba(255,255,255,0.05); padding: 2rem; text-align: center; color: rgba(255,255,255,0.3); font-size: 0.85rem;">
    © 2026 DJMaster Academy. כל הזכויות שמורות.
  </footer>
</body>
</html>
