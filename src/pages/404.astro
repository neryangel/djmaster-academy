---
import BaseLayout from '@layouts/BaseLayout.astro';
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
---

<BaseLayout title="עמוד לא נמצא | DJMaster Academy" description="העמוד שחיפשת לא קיים.">
  <Navbar />

  <main class="min-h-[70vh] flex items-center justify-center p-6 relative overflow-hidden mt-16">
    <div class="absolute inset-0 bg-gradient-to-b from-[#7b2fff]/10 via-[#00d4ff]/5 to-transparent pointer-events-none"></div>
    <div class="max-w-2xl text-center relative z-10 fade-in-up">
      <div class="text-[clamp(6rem,15vw,10rem)] leading-none font-bold text-transparent bg-clip-text bg-gradient-to-r from-[#00d4ff] to-[#7b2fff] mb-4">
        404
      </div>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">הופס! העמוד לא נמצא</h1>
      <p class="text-white/70 text-lg mb-8">
        נראה שהביט קפץ לנו. העמוד שחיפשת כנראה הוזז או לא קיים יותר.
      </p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="/" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-bold bg-[#00d4ff] text-[#0A0A0F] hover:bg-[#00d4ff]/90 hover:shadow-[0_0_30px_rgba(0,212,255,0.4)] transition-all">
          🏠 חזרה לדף הבית
        </a>
        <a href="/courses" class="inline-flex items-center gap-2 px-8 py-4 rounded-xl font-bold bg-white/10 text-white hover:bg-white/20 transition-all border border-white/10">
          📚 לקורסים שלנו
        </a>
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
