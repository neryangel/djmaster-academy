---
import { getCollection } from 'astro:content';
import LessonLayout from '@layouts/LessonLayout.astro';

export async function getStaticPaths() {
  const allLessons = await getCollection('lessons');
  const allCourses = await getCollection('courses');

  // Build a map: course_id → course data
  const courseMap = new Map();
  for (const course of allCourses) {
    courseMap.set(course.data.id, course.data);
  }

  // Group lessons by course_id and sort by lesson_number
  const lessonsByCourse = new Map<string, typeof allLessons>();
  for (const lesson of allLessons) {
    const courseId = lesson.data.course_id;
    if (!lessonsByCourse.has(courseId)) {
      lessonsByCourse.set(courseId, []);
    }
    lessonsByCourse.get(courseId)!.push(lesson);
  }

  // Sort each course's lessons
  for (const [, lessons] of lessonsByCourse) {
    lessons.sort((a, b) => a.data.lesson_number - b.data.lesson_number);
  }

  const paths = [];

  for (const lesson of allLessons) {
    const courseId = lesson.data.course_id;
    const course = courseMap.get(courseId);
    if (!course) continue;

    const courseSlug = course.slug;
    const lessonSlug = lesson.slug.split('/').pop() || lesson.slug;

    // Find prev/next lessons using optimized index derived during sorting
    const courseLessons = lessonsByCourse.get(courseId) || [];
    // Optimization: Since we already sorted courseLessons, we can just find our index once
    const idx = courseLessons.indexOf(lesson);
    const prevLesson = idx > 0 ? courseLessons[idx - 1] : null;
    const nextLesson = idx < courseLessons.length - 1 ? courseLessons[idx + 1] : null;

    paths.push({
      params: {
        courseSlug,
        lessonSlug,
      },
      props: {
        lesson,
        course,
        totalLessons: courseLessons.length,
        prevLesson: prevLesson ? {
          title: prevLesson.data.title,
          slug: prevLesson.slug.split('/').pop() || prevLesson.slug,
        } : null,
        nextLesson: nextLesson ? {
          title: nextLesson.data.title,
          slug: nextLesson.slug.split('/').pop() || nextLesson.slug,
        } : null,
        courseLessons // Inject courseLessons to build sidebar
      },
    });
  }

  return paths;
}

const { lesson, course, totalLessons, prevLesson, nextLesson, courseLessons } = Astro.props;
const { Content } = await lesson.render();

// Group lessons by module for the sidebar
const lessonsByModule = new Map();
course.modules.forEach((module: { id: string, title: string }) => {
  const moduleLessons = courseLessons.filter((l: any) => l.data.module_id === module.id);
  if (moduleLessons.length > 0) {
    lessonsByModule.set(module.id, moduleLessons);
  }
});

// Create readable Hebrew label for each module directly from the new Schema
const moduleLabels: Record<string, string> = {};
course.modules.forEach((module: { id: string, title: string }, index: number) => {
  moduleLabels[module.id] = `מודול ${index + 1} — ${module.title}`;
});
---

<LessonLayout
  title={lesson.data.title}
  description={lesson.data.description}
  courseTitle={course.title}
  courseSlug={course.slug}
  lessonNumber={lesson.data.lesson_number}
  totalLessons={totalLessons}
  duration={lesson.data.duration_minutes}
  difficulty={lesson.data.difficulty}
  keyTerms={lesson.data.key_terms}
  prevLesson={prevLesson}
  nextLesson={nextLesson}
>
  <!-- Sidebar Syllabus -->
  <div slot="sidebar" class="glass-card p-5 mb-6">
    <h3 class="text-sm font-bold text-[#00d4ff] mb-4 uppercase tracking-wide">תוכן הקורס</h3>
    {Array.from(lessonsByModule.entries()).map(([moduleId, mLessons]: [string, any[]]) => (
      <div class="mb-5 last:mb-0">
        <h4 class="text-xs font-bold text-white/50 mb-2 uppercase tracking-wide">{moduleLabels[moduleId] || moduleId}</h4>
        <ul class="space-y-1">
          {mLessons.map((l) => {
            const isCurrent = l.slug === lesson.slug;
            const lSlug = l.slug.split('/').pop() || l.slug;
            return (
              <li>
                <a
                  href={`/courses/${course.slug}/${lSlug}`}
                  class={`block py-1.5 pl-3 border-l text-sm transition-all duration-300 ${isCurrent ? 'border-[#00d4ff] text-[#00d4ff] font-semibold bg-[#00d4ff]/5 rounded-r-md' : 'border-white/10 text-white/70 hover:border-[#00d4ff]/50 hover:text-white'}`}
                >
                  <span class="inline-block w-5 text-center text-xs opacity-50 ml-1">{l.data.lesson_number}.</span>
                  {l.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </div>

  <!-- Main Content -->
  <Content />
</LessonLayout>
