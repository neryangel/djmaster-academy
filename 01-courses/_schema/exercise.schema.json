{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://djmaster.academy/schemas/exercise.json",
  "title": "DJMaster Exercise Schema",
  "description": "Validates YAML frontmatter of exercise markdown files",
  "type": "object",
  "required": ["id", "title", "module", "type", "difficulty", "duration_minutes", "points", "submission"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[0-9]{2}-[a-z-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "module": {
      "type": "string",
      "pattern": "^[0-9]{2}-[a-z-]+$"
    },
    "course": {
      "type": "string",
      "pattern": "^[0-9]{2}-[a-z-]+$"
    },
    "type": {
      "type": "string",
      "enum": ["reflection", "research", "practical", "creative", "analysis", "collaboration"]
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced", "challenge"]
    },
    "duration_minutes": {
      "type": "integer",
      "minimum": 5,
      "maximum": 120
    },
    "points": {
      "type": "integer",
      "minimum": 5,
      "maximum": 100
    },
    "submission": {
      "type": "string",
      "enum": ["text", "file", "url", "audio", "video", "image", "spreadsheet"]
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "last_updated": {
      "type": "string",
      "format": "date"
    },
    "prerequisites": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tools_required": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tools needed (e.g., Rekordbox, Spotify, pen and paper)"
    },
    "rubric": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["criterion", "points"],
        "properties": {
          "criterion": { "type": "string" },
          "points": { "type": "integer" },
          "description": { "type": "string" }
        }
      }
    }
  }
}
